{
  "manifest_version": 3,
  "name": "Markdown Vault",
  "version": "1.0.0",
  "description": "Send any URL to your Telegram bot → it gets saved as clean Markdown on your computer. Zero backend, your data.",
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "tabs",
    "scripting",
    "offscreen",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "pages/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon_16.png",
      "32": "assets/icons/icon_32.png",
      "48": "assets/icons/icon_48.png",
      "128": "assets/icons/icon_128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon_16.png",
    "32": "assets/icons/icon_32.png",
    "48": "assets/icons/icon_48.png",
    "128": "assets/icons/icon_128.png"
  }
}